# ===========================================
# 外交大臣（西班牙语外交教练机器人）环境变量
# ===========================================

# Claude API Key（必需）
# 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=your_claude_api_key_here

# 飞书机器人 Webhook URL（必需）
# 你的外交大臣机器人 Webhook：
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/1740c4ae-c0a9-4f36-8b4d-992f71b1c110

# ===========================================
# 其他飞书应用配置（如需扩展功能）
# ===========================================

# 飞书自建应用配置（用于读取多维表格等高级功能）
# FEISHU_APP_ID=your_app_id
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_APP_TOKEN=your_bitable_app_token
